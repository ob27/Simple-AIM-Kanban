# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and never committed.
#
# Get these from Firebase Console → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Get from Google reCAPTCHA Console → your site key (v3)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
